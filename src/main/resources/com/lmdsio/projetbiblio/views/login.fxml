<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<AnchorPane xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.lmdsio.projetbiblio.controllers.LoginController">
    <children>
        <VBox alignment="CENTER" layoutX="213.0" layoutY="-5.0" prefHeight="276.0" prefWidth="382.0" spacing="20.0" AnchorPane.bottomAnchor="5.0" AnchorPane.leftAnchor="5.0" AnchorPane.rightAnchor="5.0" AnchorPane.topAnchor="5.0">
            <children>
                <Label fx:id="loginText" alignment="CENTER" contentDisplay="TOP" text="Veuillez saisir vos identifiants">
                    <font>
                        <Font size="18.0" />
                    </font>
                    <VBox.margin>
                        <Insets bottom="15.0" />
                    </VBox.margin>
                </Label>
                <HBox alignment="CENTER">
                    <children>
                        <Label alignment="CENTER" contentDisplay="CENTER" prefWidth="100.0" text="Login" textAlignment="CENTER">
                            <font>
                                <Font size="13.0" />
                            </font>
                        </Label>
                        <TextField fx:id="loginField" />
                    </children>
                    <VBox.margin>
                        <Insets left="10.0" right="10.0" />
                    </VBox.margin>
                </HBox>
                <HBox alignment="CENTER" layoutX="10.0" layoutY="27.0">
                    <children>
                        <Label prefWidth="100.0" text="Mot de passe">
                            <font>
                                <Font size="13.0" />
                            </font>
                        </Label>
                        <PasswordField fx:id="passwordField" />
                    </children>
                </HBox>
                <HBox alignment="CENTER_RIGHT" layoutX="10.0" layoutY="119.0">
                    <children>
                        <Button fx:id="LoginButton" alignment="CENTER" mnemonicParsing="false" onAction="#onLoginClick" text="Connexion">
                            <font>
                                <Font size="14.0" />
                            </font>
                     <HBox.margin>
                        <Insets right="70.0" />
                     </HBox.margin>
                        </Button>
                    </children>
               <opaqueInsets>
                  <Insets />
               </opaqueInsets>
                </HBox>
            </children>
        </VBox>
    </children>
</AnchorPane>
